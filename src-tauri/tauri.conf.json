{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CaptainPassword",
  "version": "0.1.3",
  "identifier": "ai.heihuzi.captainpassword",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "船长密码箱",
        "width": 1220,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 17
        }
      },
      {
        "label": "quick-search",
        "title": "船长密码箱",
        "url": "index.html?window=quick-search",
        "width": 380,
        "height": 190,
        "minWidth": 340,
        "minHeight": 180,
        "center": true,
        "visible": false,
        "resizable": true,
        "skipTaskbar": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 12,
          "y": 13
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

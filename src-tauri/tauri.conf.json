{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OnePass Local",
  "version": "0.1.0",
  "identifier": "ai.heihuzi.onepass",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OnePass Local",
        "width": 1220,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
